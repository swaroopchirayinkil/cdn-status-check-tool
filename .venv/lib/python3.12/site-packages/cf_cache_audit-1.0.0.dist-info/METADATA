## JSON Report Structure

```json
{
  "website": "https://example.com",
  "scan_started": "2026-06-19T07:00:00Z",
  "scan_finished": "2026-06-19T07:00:45Z",
  "cloudflare": {
    "detected": true,
    "cf_ray_present": true,
    "server_header": "cloudflare",
    "apo_detected": false,
    "cache_rules_hints": [],
    "additional_notes": []
  },
  "summary": {
    "total_assets": 156,
    "cacheable_assets": 143,
    "hit": 121,
    "miss": 11,
    "dynamic": 9,
    "hit_ratio": 84.6
  },
  "assets": [
    {
      "url": "https://example.com/css/main.css",
      "asset_type": "css",
      "http_status": 200,
      "content_type": "text/css",
      "cf_cache_status": "HIT",
      "is_cacheable": true,
      "audit_result": "PASS",
      "audit_message": "Served from cache"
    }
  ]
}
```

